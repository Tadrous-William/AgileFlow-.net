@model AgileTaskManager.Models.ViewModels.AddFeedbackViewModel
@{
    ViewData["Title"] = "Leave Feedback";
}

<div class="atm-page-header">
    <div>
        <h2 class="atm-page-title">Leave Feedback</h2>
        <p class="atm-page-sub">Rate the completed task</p>
    </div>
    <a asp-controller="Task" asp-action="Details" asp-route-id="@Model.TaskId" class="atm-btn ghost">
        <i class="bi bi-arrow-left"></i> Back to Task
    </a>
</div>

<div class="row">
    <div class="col-lg-6">
        <div class="atm-card">
            <div class="atm-card-body">
                <form asp-action="Add" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="TaskId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3"></div>

                    <div class="atm-form-group">
                        <label class="atm-label">Rating *</label>
                        <div class="atm-star-picker" id="starPicker">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button" class="atm-star-btn" data-value="@i">
                                    <i class="bi bi-star-fill"></i>
                                </button>
                            }
                        </div>
                        <input asp-for="Rating" type="hidden" id="ratingInput" />
                        <span asp-validation-for="Rating" class="atm-validation"></span>
                    </div>

                    <div class="atm-form-group">
                        <label asp-for="Comment" class="atm-label">Comment (optional)</label>
                        <textarea asp-for="Comment" class="atm-textarea" rows="4"
                                  placeholder="Share your thoughts about this task…"></textarea>
                        <span asp-validation-for="Comment" class="atm-validation"></span>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="atm-btn primary">
                            <i class="bi bi-star-fill me-1"></i> Submit Feedback
                        </button>
                        <a asp-controller="Task" asp-action="Details" asp-route-id="@Model.TaskId" class="atm-btn ghost">
                            Cancel
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const stars   = document.querySelectorAll('.atm-star-btn');
const input   = document.getElementById('ratingInput');
let selected  = 0;

stars.forEach(btn => {
    btn.addEventListener('mouseenter', () => highlightStars(+btn.dataset.value));
    btn.addEventListener('mouseleave', () => highlightStars(selected));
    btn.addEventListener('click', () => {
        selected = +btn.dataset.value;
        input.value = selected;
        highlightStars(selected);
    });
});

function highlightStars(n) {
    stars.forEach((btn, i) => {
        btn.classList.toggle('active', i < n);
    });
}
</script>
}
