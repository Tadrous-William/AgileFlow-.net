@model AgileTaskManager.Models.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Register — Agile Task Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="atm-auth-body">
    <div class="atm-auth-wrapper">
        <div class="atm-auth-card">
            <div class="atm-auth-header">
                <div class="atm-auth-logo">
                    <i class="bi bi-lightning-charge-fill"></i>
                </div>
                <h1 class="atm-auth-title">Create Account</h1>
                <p class="atm-auth-sub">Join your team's workspace</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <form asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div class="atm-form-group">
                    <label asp-for="FullName" class="atm-label">Full Name</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-person atm-input-icon"></i>
                        <input asp-for="FullName" class="atm-input with-icon" placeholder="Sayed Gamea" />
                    </div>
                    <span asp-validation-for="FullName" class="atm-validation"></span>
                </div>

                <div class="atm-form-group">
                    <label asp-for="Email" class="atm-label">Email</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-envelope atm-input-icon"></i>
                        <input asp-for="Email" class="atm-input with-icon" placeholder="you@example.com" />
                    </div>
                    <span asp-validation-for="Email" class="atm-validation"></span>
                </div>

                <div class="atm-form-group">
                    <label asp-for="Password" class="atm-label">Password</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-lock atm-input-icon"></i>
                        <input asp-for="Password" type="password" class="atm-input with-icon" placeholder="Min. 8 characters" />
                    </div>
                    <span asp-validation-for="Password" class="atm-validation"></span>
                </div>

                <div class="atm-form-group">
                    <label asp-for="ConfirmPassword" class="atm-label">Confirm Password</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-lock-fill atm-input-icon"></i>
                        <input asp-for="ConfirmPassword" type="password" class="atm-input with-icon" placeholder="Repeat password" />
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="atm-validation"></span>
                </div>

                <div class="atm-form-group">
                    <label asp-for="Role" class="atm-label">Role</label>
                    <select asp-for="Role" class="atm-select" id="roleSelect">
                        <option value="Admin">Admin</option>
                        <option value="Developer">Developer</option>
                        <option value="Client">Client</option>
                    </select>
                    <small class="text-muted">Choose your access level for this account.</small>
                </div>


                <button type="submit" class="atm-btn primary w-100 mb-3">Create Account</button>

                <p class="text-center text-muted small mb-0">
                    Already have an account? <a asp-action="Login" class="atm-link">Sign in</a>
                </p>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        const roleSelect = document.getElementById('roleSelect');
        const adminSecretWrap = document.getElementById('adminSecretWrap');

        function toggleAdminSecret() {
            const isAdmin = roleSelect.value === 'Admin';
            adminSecretWrap.style.display = isAdmin ? '' : 'none';
        }

        roleSelect.addEventListener('change', toggleAdminSecret);
        toggleAdminSecret();
    </script>
</body>
</html>
