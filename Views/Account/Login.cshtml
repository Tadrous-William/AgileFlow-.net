@model AgileTaskManager.Models.ViewModels.LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Agile Task Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="atm-auth-body">
    <div class="atm-auth-wrapper">
        <div class="atm-auth-card">
            <div class="atm-auth-header">
                <div class="atm-auth-logo">
                    <i class="bi bi-kanban-fill"></i>
                </div>
                <h1 class="atm-auth-title">Agile Task Manager</h1>
                <p class="atm-auth-sub">Sign in to your workspace</p>
            </div>

            <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@ViewData["ReturnUrl"]" />

                <div class="atm-form-group">
                    <label asp-for="Email" class="atm-label">Email</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-envelope atm-input-icon"></i>
                        <input asp-for="Email" class="atm-input with-icon" placeholder="you@example.com" autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email" class="atm-validation"></span>
                </div>

                <div class="atm-form-group">
                    <label asp-for="Password" class="atm-label">Password</label>
                    <div class="atm-input-icon-wrap">
                        <i class="bi bi-lock atm-input-icon"></i>
                        <input asp-for="Password" class="atm-input with-icon" type="password" placeholder="••••••••" autocomplete="current-password" />
                    </div>
                    <span asp-validation-for="Password" class="atm-validation"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-muted small">Remember me</label>
                    </div>
                </div>

                <button type="submit" class="atm-btn primary w-100 mb-3">Sign In</button>

                <p class="text-center text-muted small mb-0">
                    Don't have an account? <a asp-action="Register" class="atm-link">Register</a>
                </p>
            </form>
        </div>
    </div>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
