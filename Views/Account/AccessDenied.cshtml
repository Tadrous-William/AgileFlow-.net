@{
    ViewData["Title"] = "Access Denied";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Access Denied — Agile Task Manager</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body class="atm-auth-body">
    <div class="atm-auth-wrapper">
        <div class="atm-auth-card text-center">
            <div class="atm-forbidden-icon">
                <i class="bi bi-shield-x"></i>
            </div>
            <h2 class="atm-forbidden-title">Access Denied</h2>
            <p class="text-muted mb-4">
                You don't have permission to view this page.<br />
                Contact your administrator if you believe this is a mistake.
            </p>
            <a asp-controller="Dashboard" asp-action="Index" class="atm-btn primary">
                <i class="bi bi-house-fill me-2"></i> Go to Dashboard
            </a>
        </div>
    </div>
</body>
</html>
