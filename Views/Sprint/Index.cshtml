@{
    ViewData["Title"] = "Sprints";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-0">⚡ Sprint Management</h2>
            <p class="text-muted mb-0">Create and manage sprints for your projects</p>
        </div>
        <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createSprintModal" id="btnNewSprint"
                @(ViewBag.SelectedProjectId == null ? "disabled" : "")>
            <i class="bi bi-plus-circle me-1"></i> New Sprint
        </button>
    </div>

    <div class="row g-4">
        <!-- Project selector -->
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-header fw-semibold">
                    <i class="bi bi-folder2-open me-1"></i> Projects
                </div>
                <div class="list-group list-group-flush" id="projectList">
                    @if (ViewBag.Projects != null)
                    {
                        foreach (var p in ViewBag.Projects)
                        {
                            var isActive = ViewBag.SelectedProjectId != null && (int)ViewBag.SelectedProjectId == (int)p.Id;
                            <a href="/Sprint?projectId=@p.Id"
                               class="list-group-item list-group-item-action d-flex justify-content-between align-items-center @(isActive ? "active" : "")">
                                <span><i class="bi bi-folder me-2"></i>@p.Name</span>
                                <span class="badge @(isActive ? "bg-white text-primary" : "bg-primary") rounded-pill">
                                    @p.Sprints.Count
                                </span>
                            </a>
                        }
                    }
                    else
                    {
                        <div class="list-group-item text-muted small">No projects found</div>
                    }
                </div>
            </div>
        </div>

        <!-- Sprint list for selected project -->
        <div class="col-md-9">
            @if (ViewBag.SelectedProjectId == null)
            {
                <div class="card">
                    <div class="card-body text-center py-5">
                        <i class="bi bi-arrow-left-circle display-4 text-muted"></i>
                        <p class="mt-3 text-muted">Select a project on the left to view and manage its sprints.</p>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <span class="fw-semibold">
                            <i class="bi bi-lightning-charge me-1"></i>
                            Sprints — @(ViewBag.SelectedProject?.Name ?? "")
                        </span>
                        <small class="text-muted">@(ViewBag.Sprints?.Count ?? 0) sprint(s)</small>
                    </div>
                    <div class="card-body p-0">
                        @if (ViewBag.Sprints == null || ViewBag.Sprints.Count == 0)
                        {
                            <div class="text-center py-5">
                                <i class="bi bi-calendar-plus display-4 text-muted"></i>
                                <p class="mt-3 text-muted">No sprints yet. Create your first sprint!</p>
                            </div>
                        }
                        else
                        {
                            <div class="table-responsive">
                                <table class="table table-hover mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Sprint Name</th>
                                            <th>Status</th>
                                            <th>Start</th>
                                            <th>End</th>
                                            <th>Duration</th>
                                            <th class="text-center">Actions</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var s in ViewBag.Sprints)
                                        {
                                            var statusClass = s.Status.ToString() switch {
                                                "Active"    => "bg-success",
                                                "Planned"   => "bg-info",
                                                "Completed" => "bg-secondary",
                                                _           => "bg-light text-dark"
                                            };
                                            var days = ((DateTime)s.EndDate - (DateTime)s.StartDate).Days + 1;
                                            <tr>
                                                <td class="fw-semibold">
                                                    <i class="bi bi-lightning-charge text-warning me-1"></i>
                                                    @s.Name
                                                </td>
                                                <td>
                                                    <span class="badge @statusClass">@s.Status</span>
                                                </td>
                                                <td>@(((DateTime)s.StartDate).ToString("MMM dd, yyyy"))</td>
                                                <td>@(((DateTime)s.EndDate).ToString("MMM dd, yyyy"))</td>
                                                <td>@days days</td>
                                                <td class="text-center">
                                                    <div class="btn-group btn-group-sm">
                                                        <a href="/Analytics/Sprint/@s.Id" class="btn btn-outline-primary" title="View Analytics">
                                                            <i class="bi bi-graph-up"></i>
                                                        </a>
                                                        <a href="/Kanban?projectId=@ViewBag.SelectedProjectId&sprintId=@s.Id" class="btn btn-outline-secondary" title="Open Kanban Board">
                                                            <i class="bi bi-kanban"></i>
                                                        </a>
                                                        @if (s.Status.ToString() == "Planned")
                                                        {
                                                            <button class="btn btn-outline-success" title="Start Sprint"
                                                                    onclick="sprintMgmt.startSprint(@s.Id, '@s.Name')">
                                                                <i class="bi bi-play-fill"></i>
                                                            </button>
                                                        }
                                                        @if (s.Status.ToString() == "Active")
                                                        {
                                                            <button class="btn btn-outline-warning" title="Complete Sprint"
                                                                    onclick="sprintMgmt.completeSprint(@s.Id, '@s.Name')">
                                                                <i class="bi bi-flag-fill"></i>
                                                            </button>
                                                        }
                                                    </div>
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Create Sprint Modal -->
<div class="modal fade" id="createSprintModal" tabindex="-1" aria-labelledby="createSprintLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="createSprintLabel">
                    <i class="bi bi-plus-circle me-2"></i>Create New Sprint
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <div id="createSprintError" class="alert alert-danger d-none"></div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Sprint Name <span class="text-danger">*</span></label>
                    <input type="text" class="form-control" id="sprintName" placeholder="e.g. Sprint 3" maxlength="100">
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Description</label>
                    <textarea class="form-control" id="sprintDescription" rows="2" placeholder="What will this sprint focus on?"></textarea>
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label fw-semibold">Start Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="sprintStartDate">
                    </div>
                    <div class="col-6 mb-3">
                        <label class="form-label fw-semibold">End Date <span class="text-danger">*</span></label>
                        <input type="date" class="form-control" id="sprintEndDate">
                    </div>
                </div>
                <div class="alert alert-info small mb-0">
                    <i class="bi bi-info-circle me-1"></i>
                    New sprints start in <strong>Planned</strong> status. Start a sprint from the list to make it Active.
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="btnCreateSprint" onclick="sprintMgmt.create()">
                    <i class="bi bi-plus-circle me-1"></i>Create Sprint
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const sprintMgmt = {
    projectId: @(ViewBag.SelectedProjectId?.ToString() ?? "null"),

    async create() {
        const name = document.getElementById('sprintName').value.trim();
        const desc = document.getElementById('sprintDescription').value.trim();
        const start = document.getElementById('sprintStartDate').value;
        const end   = document.getElementById('sprintEndDate').value;
        const errEl = document.getElementById('createSprintError');

        errEl.classList.add('d-none');

        if (!name) { errEl.textContent = 'Sprint name is required.'; errEl.classList.remove('d-none'); return; }
        if (!start) { errEl.textContent = 'Start date is required.'; errEl.classList.remove('d-none'); return; }
        if (!end)   { errEl.textContent = 'End date is required.';   errEl.classList.remove('d-none'); return; }
        if (end <= start) { errEl.textContent = 'End date must be after start date.'; errEl.classList.remove('d-none'); return; }

        const btn = document.getElementById('btnCreateSprint');
        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>Creating…';

        try {
            const res = await fetch(`/api/projects/${this.projectId}/sprints`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ projectId: this.projectId, name, description: desc, startDate: start, endDate: end })
            });

            if (!res.ok) {
                const err = await res.json().catch(() => ({ error: 'Failed to create sprint.' }));
                throw new Error(err.error || 'Failed to create sprint.');
            }

            // Reload the page to show the new sprint
            window.location.reload();
        } catch (e) {
            errEl.textContent = e.message;
            errEl.classList.remove('d-none');
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-plus-circle me-1"></i>Create Sprint';
        }
    },

    async startSprint(id, name) {
        if (!confirm(`Start sprint "${name}"? This will make it Active.`)) return;
        const res = await fetch(`/api/projects/${this.projectId}/sprints/${id}/start`, {
            method: 'POST', credentials: 'same-origin'
        });
        if (res.ok) window.location.reload();
        else alert('Could not start sprint. There may already be an active sprint in this project.');
    },

    async completeSprint(id, name) {
        if (!confirm(`Complete sprint "${name}"? Unfinished tasks will move to backlog.`)) return;
        const res = await fetch(`/api/projects/${this.projectId}/sprints/${id}/complete`, {
            method: 'POST', credentials: 'same-origin'
        });
        if (res.ok) window.location.reload();
        else alert('Could not complete sprint.');
    }
};

// Set default dates for new sprint (today → +14 days)
document.addEventListener('DOMContentLoaded', () => {
    const today = new Date().toISOString().split('T')[0];
    const twoWeeks = new Date(Date.now() + 14 * 86400000).toISOString().split('T')[0];
    document.getElementById('sprintStartDate').value = today;
    document.getElementById('sprintEndDate').value = twoWeeks;
});
</script>
}
