@model AgileTaskManager.Models.ViewModels.TaskDetailsViewModel
@using AgileTaskManager.Constants
@{
    ViewData["Title"] = Model.Title;
}

<div class="atm-page-header">
    <div>
        <h2 class="atm-page-title">@Model.Title</h2>
        <p class="atm-page-sub">
            Created @Model.CreatedAt.ToString("dd MMM yyyy")
            @if (Model.IsBlocked)
            {
                <span class="atm-tag blocked ms-2"><i class="bi bi-lock-fill"></i> Blocked by: @Model.DependsOnTitle</span>
            }
        </p>
    </div>
    <div class="d-flex gap-2">
        @if (User.IsInRole(RoleConstants.Admin))
        {
            <a asp-action="Edit" asp-route-id="@Model.Id" class="atm-btn secondary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        }
        <a asp-action="Index" class="atm-btn ghost"><i class="bi bi-arrow-left"></i> Back</a>
    </div>
</div>

<div class="row g-3">
    <!-- Left column: info + comments -->
    <div class="col-lg-8">

        <!-- Task Info -->
        <div class="atm-card mb-3">
            <div class="atm-card-header"><i class="bi bi-info-circle me-2"></i>Task Details</div>
            <div class="atm-card-body">
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="atm-detail-label">Priority</div>
                        <span class="atm-priority @Model.Priority.ToString().ToLower()">@Model.Priority</span>
                    </div>
                    <div class="col-sm-6">
                        <div class="atm-detail-label">Status</div>
                        <span class="atm-status @Model.Status.ToString().ToLower()" id="liveStatus">@Model.Status</span>
                    </div>
                    <div class="col-sm-6">
                        <div class="atm-detail-label">Assigned To</div>
                        <div>@(Model.AssignedToName ?? "Unassigned")</div>
                    </div>
                    <div class="col-sm-6">
                        <div class="atm-detail-label">Deadline</div>
                        <div class="@(Model.Deadline.HasValue && Model.Deadline < DateTime.UtcNow && Model.Status != AgileTaskManager.Models.Enums.TaskStatus.Done ? "text-danger" : "")">
                            @(Model.Deadline?.ToString("dd MMM yyyy") ?? "—")
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Description))
                    {
                        <div class="col-12">
                            <div class="atm-detail-label">Description</div>
                            <div class="atm-description">@Model.Description</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Update Status (Admin + Developer) -->
        @if (User.IsInRole("Admin") || User.IsInRole("Developer"))
        {
            <div class="atm-card mb-3">
                <div class="atm-card-header"><i class="bi bi-arrow-repeat me-2"></i>Update Status</div>
                <div class="atm-card-body">
                    <form asp-action="UpdateStatus" method="post" class="d-flex gap-2 align-items-center flex-wrap">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <select name="newStatus" class="atm-filter-select">
                            @foreach (var s in Enum.GetValues<AgileTaskManager.Models.Enums.TaskStatus>())
                            {
                                <option value="@s" selected="@(s == Model.Status ? "selected" : null)">@s</option>
                            }
                        </select>
                        <button type="submit" class="atm-btn primary">Update</button>
                        @if (Model.IsBlocked)
                        {
                            <span class="text-warning small"><i class="bi bi-exclamation-triangle"></i> Warning: blocked task</span>
                        }
                    </form>
                </div>
            </div>
        }

        <!-- Comments -->
        <div class="atm-card mb-3">
            <div class="atm-card-header">
                <span><i class="bi bi-chat-dots-fill me-2"></i>Comments (@Model.Comments.Count)</span>
            </div>
            <div class="atm-card-body">
                <!-- Live comment feed -->
                <div id="commentFeed">
                    @if (!Model.Comments.Any())
                    {
                        <div class="atm-empty small" id="noComments">No comments yet. Be the first!</div>
                    }
                    @foreach (var c in Model.Comments)
                    {
                        <div class="atm-comment">
                            <div class="atm-comment-avatar">@c.AuthorName.Substring(0, 1).ToUpper()</div>
                            <div class="atm-comment-body">
                                <div class="atm-comment-header">
                                    <span class="atm-comment-author">@c.AuthorName</span>
                                    <span class="atm-comment-time">@c.CreatedAt.ToString("dd MMM, HH:mm")</span>
                                    @if (User.IsInRole(RoleConstants.Admin))
                                    {
                                        <form asp-action="DeleteComment" method="post" class="d-inline ms-auto">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="commentId" value="@c.Id" />
                                            <input type="hidden" name="taskId" value="@Model.Id" />
                                            <button type="submit" class="atm-comment-delete" title="Delete">
                                                <i class="bi bi-x"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                                <div class="atm-comment-text">@c.Content</div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Add comment (Admin + Developer + Client) -->
                @if (User.IsInRole(RoleConstants.Admin) || User.IsInRole(RoleConstants.Developer) || User.IsInRole(RoleConstants.Client))
                {
                    <form asp-action="AddComment" method="post" class="mt-3" id="commentForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="TaskId" value="@Model.Id" />
                        <div class="d-flex gap-2">
                            <textarea name="Content" id="commentInput" class="atm-textarea" rows="2"
                                      placeholder="Write a comment…" required></textarea>
                            <button type="submit" class="atm-btn primary align-self-end">
                                <i class="bi bi-send-fill"></i>
                            </button>
                        </div>
                    </form>
                }
            </div>
        </div>

        <!-- Attachments -->
        <div class="atm-card mb-3">
            <div class="atm-card-header"><i class="bi bi-paperclip me-2"></i>Attachments (@Model.Attachments.Count)</div>
            <div class="atm-card-body">
                @if (User.IsInRole(RoleConstants.Admin) || User.IsInRole(RoleConstants.Developer) || User.IsInRole(RoleConstants.Client))
                {
                    <form asp-action="UploadAttachment" method="post" enctype="multipart/form-data" class="d-flex flex-wrap gap-2 align-items-center mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="taskId" value="@Model.Id" />
                        <input type="file" name="file" class="atm-input" required />
                        <button type="submit" class="atm-btn primary">
                            <i class="bi bi-upload"></i> Upload File
                        </button>
                    </form>
                }

                @if (!Model.Attachments.Any())
                {
                    <div class="atm-empty small">No files attached.</div>
                }
                else
                {
                    <ul class="atm-file-list">
                        @foreach (var a in Model.Attachments)
                        {
                            <li class="atm-file-item">
                                <i class="bi bi-file-earmark-fill"></i>
                                <a asp-action="DownloadAttachment" asp-route-id="@a.Id" class="atm-link">@a.FileName</a>
                                <span class="text-muted ms-auto small">
                                    @(a.FileSizeBytes / 1024) KB · @a.UploadedAt.ToString("dd MMM")
                                </span>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>

        <!-- Client Feedback -->
        @if (Model.Feedback != null)
        {
            <div class="atm-card mb-3">
                <div class="atm-card-header"><i class="bi bi-star-fill me-2"></i>Client Feedback</div>
                <div class="atm-card-body">
                    <div class="atm-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <i class="bi @(i <= Model.Feedback.Rating ? "bi-star-fill" : "bi-star") atm-star"></i>
                        }
                        <span class="ms-2">@Model.Feedback.Rating / 5</span>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Feedback.Comment))
                    {
                        <p class="mt-2 mb-0 text-muted">@Model.Feedback.Comment</p>
                    }
                    <small class="text-muted">— @Model.Feedback.ClientName, @Model.Feedback.CreatedAt.ToString("dd MMM yyyy")</small>
                </div>
            </div>
        }
        else if (User.IsInRole(RoleConstants.Client) && Model.Status == AgileTaskManager.Models.Enums.TaskStatus.Done)
        {
            <div class="atm-card mb-3">
                <div class="atm-card-header"><i class="bi bi-star me-2"></i>Leave Feedback</div>
                <div class="atm-card-body">
                    <a asp-controller="Feedback" asp-action="Add" asp-route-taskId="@Model.Id" class="atm-btn primary">
                        Rate this task
                    </a>
                </div>
            </div>
        }

    </div>

    <!-- Right column: Activity Log -->
    <div class="col-lg-4">
        <div class="atm-card sticky-top" style="top: 80px;">
            <div class="atm-card-header"><i class="bi bi-clock-history me-2"></i>Activity Log</div>
            <div class="atm-card-body p-0">
                @if (!Model.ActivityLogs.Any())
                {
                    <div class="atm-empty small">No activity yet.</div>
                }
                else
                {
                    <ul class="atm-activity-list">
                        @foreach (var a in Model.ActivityLogs)
                        {
                            <li class="atm-activity-item">
                                <div class="atm-activity-dot"></div>
                                <div class="atm-activity-content">
                                    <div class="atm-activity-action">@a.Action</div>
                                    <div class="atm-activity-meta">
                                        <span>@a.ActorName</span>
                                        <span>@a.Timestamp.ToString("dd MMM, HH:mm")</span>
                                    </div>
                                    @if (a.OldValue != null && a.NewValue != null)
                                    {
                                        <div class="atm-activity-diff">
                                            <span class="old">@a.OldValue</span>
                                            <i class="bi bi-arrow-right"></i>
                                            <span class="new">@a.NewValue</span>
                                        </div>
                                    }
                                </div>
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
const taskId = "@Model.Id";
const currentUser = "@User.Identity?.Name";

// ── SignalR Connection ─────────────────────────────────────────────────────
const connection = new signalR.HubConnectionBuilder()
    .withUrl("/taskHub")
    .withAutomaticReconnect()
    .build();

connection.start().then(() => {
    connection.invoke("JoinTaskGroup", taskId);
    document.getElementById('signalrStatus').classList.add('connected');
}).catch(console.error);

// ── Receive live comment ───────────────────────────────────────────────────
connection.on("ReceiveComment", (author, content, time) => {
    const noComments = document.getElementById('noComments');
    if (noComments) noComments.remove();

    const feed = document.getElementById('commentFeed');
    const div  = document.createElement('div');
    div.className = 'atm-comment atm-comment-live';
    div.innerHTML = `
        <div class="atm-comment-avatar">${author.charAt(0).toUpperCase()}</div>
        <div class="atm-comment-body">
            <div class="atm-comment-header">
                <span class="atm-comment-author">${author}</span>
                <span class="atm-comment-time">${time}</span>
            </div>
            <div class="atm-comment-text">${content}</div>
        </div>`;
    feed.appendChild(div);
    div.scrollIntoView({ behavior: 'smooth' });
});

// ── Receive live status update ─────────────────────────────────────────────
connection.on("ReceiveStatusUpdate", (newStatus, changedBy) => {
    const badge = document.getElementById('liveStatus');
    if (badge) {
        badge.textContent   = newStatus;
        badge.className     = `atm-status ${newStatus.toLowerCase()}`;
    }
    showToast(`Status changed to ${newStatus} by ${changedBy}`);
});

// ── Intercept comment form to also broadcast via SignalR ──────────────────
document.getElementById('commentForm')?.addEventListener('submit', async function(e) {
    const content = document.getElementById('commentInput').value.trim();
    if (!content) return;
    const now = new Date().toLocaleString('en-GB', { day:'2-digit', month:'short', hour:'2-digit', minute:'2-digit' });
    try {
        await connection.invoke("SendComment", taskId, currentUser, content, now);
    } catch(_) {}
    // form submits normally to persist to DB
});

function showToast(msg) {
    const t = document.createElement('div');
    t.className = 'atm-toast';
    t.textContent = msg;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 3500);
}
</script>
}
