@model AgileTaskManager.Models.ViewModels.TaskEditViewModel
@{
    ViewData["Title"] = "Edit Task";
}

<div class="atm-page-header">
    <div>
        <h2 class="atm-page-title">Edit Task</h2>
        <p class="atm-page-sub">#@Model.Id</p>
    </div>
    <a asp-action="Details" asp-route-id="@Model.Id" class="atm-btn ghost"><i class="bi bi-arrow-left"></i> Back</a>
</div>

<div class="row">
    <div class="col-lg-7">
        <div class="atm-card">
            <div class="atm-card-body">
                <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
                    @Html.AntiForgeryToken()
                    <input asp-for="Id" type="hidden" />
                    <div asp-validation-summary="All" class="alert alert-danger small mb-3"></div>

                    <div class="atm-form-group">
                        <label asp-for="Title" class="atm-label">Title *</label>
                        <input asp-for="Title" class="atm-input" />
                        <span asp-validation-for="Title" class="atm-validation"></span>
                    </div>

                    <div class="atm-form-group">
                        <label asp-for="Description" class="atm-label">Description</label>
                        <textarea asp-for="Description" class="atm-textarea" rows="4"></textarea>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-4">
                            <div class="atm-form-group">
                                <label asp-for="Priority" class="atm-label">Priority *</label>
                                <select asp-for="Priority" class="atm-select"
                                        asp-items="Html.GetEnumSelectList<AgileTaskManager.Models.Enums.TaskPriority>()">
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="atm-form-group">
                                <label asp-for="Status" class="atm-label">Status *</label>
                                <select asp-for="Status" class="atm-select"
                                        asp-items="Html.GetEnumSelectList<AgileTaskManager.Models.Enums.TaskStatus>()">
                                </select>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="atm-form-group">
                                <label asp-for="StartDate" class="atm-label">Start Date</label>
                                <input asp-for="StartDate" type="datetime-local" class="atm-input" />
                                <span asp-validation-for="StartDate" class="atm-validation"></span>
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="atm-form-group">
                                <label asp-for="Deadline" class="atm-label">Deadline</label>
                                <input asp-for="Deadline" type="date" class="atm-input" />
                                <span asp-validation-for="Deadline" class="atm-validation"></span>
                            </div>
                        </div>
                    </div>

                    <div class="atm-form-group">
                        <label asp-for="AssignedToId" class="atm-label">Assign To</label>
                        <select asp-for="AssignedToId" class="atm-select" asp-items="ViewBag.Members">
                            <option value="">— Unassigned —</option>
                        </select>
                    </div>

                    <div class="atm-form-group">
                        <label asp-for="DependsOnId" class="atm-label">Depends On</label>
                        <select asp-for="DependsOnId" class="atm-select">
                            <option value="">— No dependency —</option>
                            @foreach (var t in (ViewBag.AllTasks as List<AgileTaskManager.Models.ViewModels.TaskListViewModel> ?? new()))
                            {
                                if (t.Id != Model.Id)
                                {
                                    <option value="@t.Id" selected="@(Model.DependsOnId == t.Id ? "selected" : null)">@t.Title</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="atm-btn primary">
                            <i class="bi bi-floppy"></i> Save Changes
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="atm-btn ghost">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
